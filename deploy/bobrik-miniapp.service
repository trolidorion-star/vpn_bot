[Unit]
Description=Bobrik Mini App FastAPI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bobrik-vpn
Environment=PYTHONUNBUFFERED=1
Environment="BOT_TOKEN=CHANGE_ME_BOT_TOKEN"
EnvironmentFile=-/opt/bobrik-vpn/.env
ExecStart=/usr/bin/python3 -m uvicorn webapp.backend.main:app --app-dir /opt/bobrik-vpn --host 0.0.0.0 --port 8090
Restart=always
RestartSec=2
StartLimitIntervalSec=60
StartLimitBurst=30
TimeoutStopSec=20
LimitNOFILE=65535
StandardOutput=append:/var/log/bobrik.log
StandardError=append:/var/log/bobrik.log

[Install]
WantedBy=multi-user.target
