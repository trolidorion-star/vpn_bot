[Unit]
Description=Yadreno VPN Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/my-private
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/root/my-private/.env
ExecStart=/usr/bin/python3 -u main.py
Restart=always
RestartSec=2
StartLimitIntervalSec=60
StartLimitBurst=30
TimeoutStopSec=25
LimitNOFILE=65535
StandardOutput=append:/var/log/bobrik.log
StandardError=append:/var/log/bobrik.log

[Install]
WantedBy=multi-user.target
